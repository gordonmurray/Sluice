{
 "uid": "sluice-payments",
 "title": "Sluice \u2014 payments & activity",
 "tags": [
  "sluice",
  "x402"
 ],
 "schemaVersion": 39,
 "version": 1,
 "refresh": "10s",
 "time": {
  "from": "now-1h",
  "to": "now"
 },
 "panels": [
  {
   "id": 1,
   "type": "stat",
   "title": "Revenue (USDC)",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 0,
    "y": 0
   },
   "datasource": {
    "type": "postgres",
    "uid": "pg"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "postgres",
      "uid": "pg"
     },
     "format": "table",
     "rawQuery": true,
     "rawSql": "SELECT COALESCE(sum(amount_micro_usdc), 0) / 1000000.0 AS revenue FROM payments WHERE $__timeFilter(created_at) AND success;"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "currencyUSD",
     "decimals": 2
    },
    "overrides": []
   }
  },
  {
   "id": 2,
   "type": "stat",
   "title": "Paid requests (total)",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 6,
    "y": 0
   },
   "datasource": {
    "type": "postgres",
    "uid": "pg"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "postgres",
      "uid": "pg"
     },
     "format": "table",
     "rawQuery": true,
     "rawSql": "SELECT count(*) AS paid_requests FROM payments WHERE $__timeFilter(created_at) AND success;"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "none"
    },
    "overrides": []
   }
  },
  {
   "id": 3,
   "type": "table",
   "title": "Revenue by caller",
   "gridPos": {
    "h": 6,
    "w": 12,
    "x": 12,
    "y": 0
   },
   "datasource": {
    "type": "postgres",
    "uid": "pg"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "postgres",
      "uid": "pg"
     },
     "format": "table",
     "rawQuery": true,
     "rawSql": "SELECT COALESCE(caller, '(anonymous)') AS caller, path, count(*) AS paid_requests, sum(amount_micro_usdc) / 1000000.0 AS revenue_usdc FROM payments WHERE $__timeFilter(created_at) AND success GROUP BY 1, 2 ORDER BY revenue_usdc DESC;"
    }
   ],
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   }
  },
  {
   "id": 4,
   "type": "timeseries",
   "title": "Paid requests over time",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 6
   },
   "datasource": {
    "type": "postgres",
    "uid": "pg"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "postgres",
      "uid": "pg"
     },
     "format": "time_series",
     "rawQuery": true,
     "rawSql": "SELECT $__timeGroup(created_at, '1m') AS time, count(*) AS paid_requests FROM payments WHERE $__timeFilter(created_at) AND success GROUP BY 1 ORDER BY 1;"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "none",
     "custom": {
      "drawStyle": "bars",
      "fillOpacity": 60
     }
    },
    "overrides": []
   }
  },
  {
   "id": 5,
   "type": "timeseries",
   "title": "Settle latency (facilitator POST /settle)",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 6
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"facilitator\",span_kind=\"SPAN_KIND_SERVER\",span_name=\"POST /settle\"}[$__rate_interval])))",
     "legendFormat": "p95"
    },
    {
     "refId": "B",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"facilitator\",span_kind=\"SPAN_KIND_SERVER\",span_name=\"POST /settle\"}[$__rate_interval])))",
     "legendFormat": "p50"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "ms"
    },
    "overrides": []
   }
  },
  {
   "id": 6,
   "type": "timeseries",
   "title": "Facilitator settle/verify rate",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 14
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "expr": "sum by (span_name) (rate(traces_span_metrics_calls_total{service_name=\"facilitator\",span_kind=\"SPAN_KIND_SERVER\",span_name=~\"POST /settle|POST /verify\"}[$__rate_interval]))",
     "legendFormat": "{{span_name}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "reqps"
    },
    "overrides": []
   }
  },
  {
   "id": 7,
   "type": "timeseries",
   "title": "Gateway requests by decision",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 22
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "expr": "sum by (decision, status) (rate(sluice_gateway_requests_total[$__rate_interval]))",
     "legendFormat": "{{decision}} / {{status}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "reqps"
    },
    "overrides": []
   }
  },
  {
   "id": 8,
   "type": "timeseries",
   "title": "Gateway request latency by decision (p95)",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 22
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "expr": "histogram_quantile(0.95, sum by (le, decision) (rate(sluice_gateway_request_duration_seconds_bucket[$__rate_interval])))",
     "legendFormat": "{{decision}} p95"
    },
    {
     "refId": "B",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "expr": "histogram_quantile(0.50, sum by (le, decision) (rate(sluice_gateway_request_duration_seconds_bucket[$__rate_interval])))",
     "legendFormat": "{{decision}} p50"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   }
  },
  {
   "id": 9,
   "type": "timeseries",
   "title": "Origin outcomes per paid request",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 30
   },
   "datasource": {
    "type": "postgres",
    "uid": "pg"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "postgres",
      "uid": "pg"
     },
     "format": "time_series",
     "rawSql": "SELECT $__timeGroup(created_at, '1m') AS time, COALESCE(origin_status::text, 'unknown') AS metric, count(*) AS requests FROM payments WHERE $__timeFilter(created_at) AND success GROUP BY 1, 2 ORDER BY 1",
     "rawQuery": true
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "short"
    },
    "overrides": []
   }
  },
  {
   "id": 10,
   "type": "timeseries",
   "title": "Gateway errors (4xx/5xx, excluding 402 quotes)",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 30
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "expr": "sum by (decision, status) (rate(sluice_gateway_requests_total{status=~\"4..|5..\",status!=\"402\"}[$__rate_interval]))",
     "legendFormat": "{{decision}} / {{status}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "reqps"
    },
    "overrides": []
   }
  },
  {
   "id": 11,
   "type": "stat",
   "title": "Paid but failed (refund queue: origin_status >= 500 or unknown)",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 0,
    "y": 38
   },
   "datasource": {
    "type": "postgres",
    "uid": "pg"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "postgres",
      "uid": "pg"
     },
     "format": "table",
     "rawSql": "SELECT count(*) AS refund_queue FROM payments WHERE $__timeFilter(created_at) AND (origin_status >= 500 OR origin_status IS NULL)",
     "rawQuery": true
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "short"
    },
    "overrides": []
   }
  },
  {
   "id": 12,
   "type": "stat",
   "title": "Gateway request rate (all decisions)",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 6,
    "y": 38
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "expr": "sum(rate(sluice_gateway_requests_total[$__rate_interval])) or vector(0)",
     "legendFormat": "req/s"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "reqps"
    },
    "overrides": []
   }
  }
 ]
}